# === LLM Configuration ===
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=                     # Optional — for multi-LLM support
GOOGLE_API_KEY=                        # Optional — for Gemini support

# Per-agent LLM overrides (JSON). Example:
# AGENT_LLM_OVERRIDES={"research_agent": {"provider": "anthropic", "model": "claude-sonnet-4-20250514"}}
AGENT_LLM_OVERRIDES={}

# === Telegram ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# JSON list of allowed user IDs. Empty list = allow everyone (dev mode).
TELEGRAM_ALLOWED_USERS=[]

# === Encryption ===
# AES-256 key for encrypting sensitive data (contacts, vault).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, auto-generated on first run (save it or you lose access to encrypted data!)
ENCRYPTION_KEY=

# === Vector Search (Semantic Memory) ===
VECTOR_DB_ENABLED=true
VECTOR_DB_PATH=data/vectors
EMBEDDING_PROVIDER=openai                  # "openai" or "ollama"
EMBEDDING_MODEL=text-embedding-3-small     # or "nomic-embed-text" for Ollama

# === Google (Gmail + Calendar) ===
# Download credentials.json from Google Cloud Console, then run: python -m jarvis.auth.google_auth
GOOGLE_CREDENTIALS_PATH=
GOOGLE_TOKEN_PATH=data/google_token.json

# === GitHub ===
# Generate at https://github.com/settings/tokens
GITHUB_TOKEN=

# === Twilio (SMS + WhatsApp) ===
# Sign up at https://www.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=                       # e.g., +1234567890
TWILIO_WHATSAPP_NUMBER=                    # e.g., +14155238886

# === Notion ===
# Create integration at https://www.notion.so/my-integrations
NOTION_TOKEN=

# === Spotify ===
# Create app at https://developer.spotify.com/dashboard
# Then run: python -m jarvis.auth.spotify_auth
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_TOKEN_PATH=data/spotify_token.json

# === Database ===
DATABASE_PATH=data/jarvis.db

# === Memory ===
MEMORY_WINDOW=20

# === Deployment ===
WEBHOOK_URL=
LOG_LEVEL=INFO
